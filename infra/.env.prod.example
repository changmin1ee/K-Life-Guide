# ─── AWS RDS (MySQL) ──────────────────────────────────────────────────────────
RDS_ENDPOINT=klife-guide.xxxxxxxxxx.ap-northeast-2.rds.amazonaws.com
MYSQL_DATABASE=klife_guide
RDS_USERNAME=admin
RDS_PASSWORD=

# ─── MongoDB (EC2 내 컨테이너) ────────────────────────────────────────────────
MONGO_USERNAME=admin
MONGO_PASSWORD=
MONGO_DATABASE=klife_guide
MONGO_HOST=mongodb

# ─── Redis (EC2 내 컨테이너) ──────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=klife-guide

# ─── ECR Image ────────────────────────────────────────────────────────────────
ECR_IMAGE=123456789.dkr.ecr.ap-northeast-2.amazonaws.com/klife-guide:latest

# ─── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=api.klife-guide.com
